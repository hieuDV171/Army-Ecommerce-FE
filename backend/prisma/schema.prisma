datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                Int      @id @default(autoincrement())
  phone_number      String   @unique
  password          String
  username          String
  email             String?
  firstname         String?
  lastname          String?
  address           String?
  city              String?
  avatar            String?
  cover_image       String?
  cover_image_web   String?
  status            String?
  listing           Int      @default(0)
  followed          Boolean  @default(false)
  is_blocked        Boolean  @default(false)
  online            Int      @default(1)
  role              String   @default("soldier")
  created_at        DateTime @default(now())

  // Bổ sung các cấu hình push settings và ví
  dev_token         String?
  dev_type          String?
  push_like         String   @default("1")
  push_comment      String   @default("1")
  push_transaction  String   @default("1")
  push_announcement String   @default("1")
  push_sound_on     String   @default("1")
  push_sound_default String?
  available_balance Float    @default(1000000.0)
  pending_balance   Float    @default(0.0)
  reset_code        String?

  products          Product[]
  comments          Comment[]
  rates             Rate[]
  orders            Order[]
  addresses         OrderAddress[]
}

model Brand {
  id          Int       @id @default(autoincrement())
  name        String
  category_id Int
  products    Product[]
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  parent_id Int       @default(0)
  products  Product[]
}

model OrderAddress {
  id             Int      @id @default(autoincrement())
  user_id        Int
  receiver_name  String
  phone          String
  address        String
  full_address   String
  address_detail String?
  lat            Float?
  lng            Float?
  is_default     Boolean  @default(false)
  is_warehouse   Boolean  @default(false) // Phục vụ cho kho hàng ship_from

  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  products       Product[] // Các sản phẩm gửi đi từ địa chỉ kho này
  orders         Order[]
}

model Product {
  id           Int      @id @default(autoincrement())
  title        String
  price        Float
  description  String
  brand_id     Int
  category_id  Int
  ship_from_id Int
  seller_id    Int
  image_urls   String   // Lưu mảng URL dạng chuỗi JSON: ["url1", "url2"]
  created_at   DateTime @default(now())
  status       String   @default("new")

  brand        Brand        @relation(fields: [brand_id], references: [id])
  category     Category     @relation(fields: [category_id], references: [id])
  ship_from    OrderAddress @relation(fields: [ship_from_id], references: [id])
  seller       User         @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  variants     ProductVariant[]
  videos       ProductVideo[]
  comments     Comment[]
  rates        Rate[]
  order_items  OrderItem[]
}

model ProductVariant {
  id         Int     @id @default(autoincrement())
  product_id Int
  size       String
  stock      Int
  color      String
  weight     Float

  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model ProductVideo {
  id         Int     @id @default(autoincrement())
  product_id Int
  url        String

  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model Comment {
  id         Int      @id @default(autoincrement())
  product_id Int
  user_id    Int
  content    String
  created_at DateTime @default(now())

  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Rate {
  id          Int      @id @default(autoincrement())
  user_id     Int
  level       Int
  content     String
  product_id  Int?
  purchase_id String? // Ma don hang (co the null)
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model Order {
  id          String   @id // Ma don hang tu sinh dang String
  buyer_id    Int
  status      String   @default("pending")
  total_price Float
  source      String
  address_id  Int
  note        String?
  created_at  DateTime @default(now())

  buyer       User         @relation(fields: [buyer_id], references: [id], onDelete: Cascade)
  address     OrderAddress @relation(fields: [address_id], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  order_id   String
  product_id Int
  quantity   Int
  price      Float

  order      Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [product_id], references: [id])
}

model Conversation {
  id           Int      @id @default(autoincrement())
  partner_id   Int
  user_id      Int
  last_message String?
  updated_at   DateTime @default(now())
}

model Message {
  id              Int      @id @default(autoincrement())
  conversation_id Int
  sender_id       Int
  receiver_id     Int
  message         String
  type_message    String
  product_id      Int?
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())
}

model News {
  id         Int      @id @default(autoincrement())
  title      String
  content    String
  image_url  String?
  created_at DateTime @default(now())
}

model Notification {
  id              Int      @id @default(autoincrement())
  user_id         Int
  title           String
  content         String
  type            String   // announce, comment, like, transaction, chat, order
  group           Int      @default(0)
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())
}

model WalletTransaction {
  id          Int      @id @default(autoincrement())
  user_id     Int
  amount      Float
  type        String   // income, expense, refund, withdraw, reward
  description String
  created_at  DateTime @default(now())
}

model SavedSearch {
  id         Int      @id @default(autoincrement())
  user_id    Int
  keyword    String
  created_at DateTime @default(now())
}

model ProductLike {
  id         Int      @id @default(autoincrement())
  user_id    Int
  product_id Int
  created_at DateTime @default(now())

  @@unique([user_id, product_id])
}

model UserFollow {
  id          Int      @id @default(autoincrement())
  follower_id Int
  following_id Int
  created_at  DateTime @default(now())

  @@unique([follower_id, following_id])
}

model UserBlock {
  id          Int      @id @default(autoincrement())
  user_id     Int
  blocked_id  Int
  created_at  DateTime @default(now())

  @@unique([user_id, blocked_id])
}

